# Copy this to .env and fill in your values
# cp .env.example .env

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Africa/Johannesburg

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=rpi.riaanjlagrange.com

# ── Pi-hole ───────────────────────────────────────────────────────────────────
PIHOLE_PASSWORD=changeme

# ── API Keys ──────────────────────────────────────────────────────────────────
RADARR_API_KEY=
SONARR_API_KEY=
PLEX_TOKEN=

# ── Plex URL (host IP, not container name — Plex runs on host network) ────────
PLEX_URL=http://172.17.0.1:32400

# ── ntfy ──────────────────────────────────────────────────────────────────────
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# ── Storage alerts ────────────────────────────────────────────────────────────
ALERT_THRESHOLD_GB=20
CHECK_INTERVAL_MINUTES=5

# ── Public URLs (used in ntfy notification links) ─────────────────────────────
DASHBOARD_URL=https://rpi.riaanjlagrange.com
STORAGE_URL=https://storage.rpi.riaanjlagrange.com
